{
  "name": "cloudbox",
  "version": "0.0.1",
  "description": "Synthetic cloud computers for long-horizon agent practice on Cloudflare.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun --filter @cloudbox/web build",
    "dev": "bun run build && bun alchemy dev",
    "deploy": "bun run build && wrangler deploy",
    "alchemy:deploy": "bun run build && bun alchemy deploy",
    "destroy": "bun alchemy destroy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "node scripts/e2e.mjs",
    "check": "bun run build && npm run typecheck && npm run test"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "docs"
  ],
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.58",
    "@effect/platform-node": "4.0.0-beta.58",
    "alchemy": "2.0.0-beta.25",
    "effect": "4.0.0-beta.58"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260430.1",
    "@types/node": "^24.10.1",
    "playwright": "^1.57.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.86.0"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22"
  }
}
