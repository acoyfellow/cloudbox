---
import Base from "@/layouts/Base.astro";
import SampleAgent from "@/components/SampleAgent.tsx";
import { agentLaunchSpec } from "../../../seed/agent-launch.ts";
---

<Base title="Cloudbox · Demo">
  <div class="mx-auto max-w-6xl px-4 py-10 md:py-12">
    <header class="mb-8">
      <h1 class="text-3xl font-semibold tracking-tight text-kumo-default md:text-4xl">
        Cloudbox dogfoods itself.
      </h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-kumo-strong">
        One constrained agent reviews Cloudbox's own launch docs, asks for
        skeptical review, writes a launch artifact, submits a decision, and gets graded from receipts.
      </p>
    </header>

    <SampleAgent client:load spec={agentLaunchSpec} />
  </div>
</Base>
