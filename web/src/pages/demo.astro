---
import Base from "@/layouts/Base.astro";
import Playground from "@/components/Playground.tsx";
---

<Base title="Cloudbox · Demo">
  <div class="mx-auto max-w-6xl px-4 py-10 md:py-12">
    <header class="mb-8">
      <h1 class="text-3xl font-semibold tracking-tight text-kumo-default md:text-4xl">
        Demo
      </h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-kumo-strong">
        Run a public GitHub repo in Cloudbox. The Worker sends the job to a Cloudflare Container,
        then returns command receipts, logs, and an artifact you can inspect.
      </p>
    </header>

    <Playground client:load />
  </div>
</Base>
