---
export const prerender = true;

import { Code } from "astro:components";
import Base from "@/layouts/Base.astro";

const bootSteps = ["clone", "boot", "run", "verify", "artifact"];

const primaryCode = `const run = await fetch("https://cloudbox.coey.dev/runs", {
  method: "POST",
  headers: {
    "content-type": "application/json",
    authorization: "Bearer $CLOUDBOX_API_TOKEN",
  },
  body: JSON.stringify({
    repo: "https://github.com/acoyfellow/cloudbox",
    commands: ["pnpm install --ignore-scripts"],
    verify: ["pnpm run build", "pnpm run test"],
    artifact: "HANDOFF.md",
  }),
}).then((res) => res.json());

console.log(run);

// ok: true
// receipts: clone → install → build → test → diff
// artifact: HANDOFF.md
// runner: Cloudflare Container`;

const runs = [
  ["Upgrade packages", "build · test · browser check"],
  ["Find flakes", "repeat until stable"],
  ["Review PRs", "checkout · test · report"],
  ["Prove migrations", "apply · verify · handoff"],
  ["Prepare releases", "final checks · release note"],
];
---

<Base>
  <main class="mx-auto max-w-6xl overflow-x-clip px-4 py-14 md:py-20">
    <section class="relative grid min-w-0 gap-10 overflow-hidden rounded-[2rem] border border-orange-200/70 bg-[#08090d] p-5 text-white shadow-2xl shadow-orange-950/10 sm:p-8 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] lg:items-center">
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_72%_28%,rgba(246,130,31,0.34),transparent_34%),linear-gradient(120deg,rgba(255,255,255,0.08)_1px,transparent_1px)] bg-[length:auto,28px_28px]" aria-hidden="true"></div>
      <div class="relative max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-orange-200">Repo in. Proof out.</p>
        <h1 class="mt-4 text-5xl font-semibold tracking-tight text-white sm:text-6xl md:text-7xl">
          Give your agent a computer.
        </h1>
        <p class="mt-6 text-base leading-7 text-orange-50/78 sm:text-lg sm:leading-8">
          Cloudbox runs repo work in a fresh Cloudflare Container, verifies the result, and returns receipts plus an artifact you can inspect.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/demo"
            class="inline-flex items-center gap-2 rounded-md bg-[#f38020] px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-orange-950/30 hover:bg-[#faae40]"
          >
            Try demo
          </a>
          <a
            href="/docs"
            class="inline-flex items-center gap-2 rounded-md border border-white/18 bg-white/7 px-4 py-2 text-sm font-medium text-white hover:bg-white/12"
          >
            Browse docs
          </a>
        </div>
      </div>

      <div class="relative min-w-0 rounded-3xl border border-white/12 bg-white/[0.04] p-4 shadow-2xl shadow-black/30 backdrop-blur">
        <div class="mb-4 flex items-center justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-orange-200/80">Computer boot</p>
            <h2 class="mt-1 text-lg font-semibold text-white">clone → boot → run → verify → artifact</h2>
          </div>
          <span class="rounded-full border border-orange-200/20 bg-orange-300/10 px-2.5 py-1 font-mono text-xs text-orange-100">live proof</span>
        </div>

        <div class="grid gap-4 sm:grid-cols-[8rem_minmax(0,1fr)] sm:items-center">
          <div class="space-y-2">
            {bootSteps.map((step, index) => (
              <div class="boot-step flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-orange-100/80" style={`--i:${index}`}>
                <span class="size-1.5 rounded-full bg-orange-300"></span>
                {step}
              </div>
            ))}
          </div>

          <div class="machine-wrap relative mx-auto aspect-square w-full max-w-[25rem] overflow-hidden rounded-3xl border border-white/12 bg-black/35 p-6">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(251,173,65,0.2),transparent_54%)]"></div>
            <div class="machine relative mx-auto grid size-full max-h-[20rem] max-w-[20rem] grid-cols-4 gap-2 rounded-[1.6rem] border border-orange-200/30 bg-orange-400/10 p-4 shadow-[0_0_60px_rgba(246,130,31,0.28)]">
              {Array.from({ length: 16 }).map((_, index) => (
                <span class="tile rounded-lg border border-orange-100/10 bg-orange-200/12" style={`--i:${index}`}></span>
              ))}
              <div class="scan absolute inset-x-4 top-4 h-px bg-lime-300/80 shadow-[0_0_20px_rgba(190,242,100,0.95)]"></div>
            </div>
            <div class="artifact absolute bottom-6 left-1/2 w-44 -translate-x-1/2 rounded-xl border border-lime-200/50 bg-lime-300/12 px-4 py-3 shadow-[0_0_30px_rgba(190,242,100,0.22)]">
              <p class="font-mono text-xs font-semibold text-lime-100">HANDOFF.md ✓</p>
              <p class="mt-1 font-mono text-[0.68rem] text-lime-100/60">receipts: 4</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-14 border-t border-kumo-line pt-10">
      <div class="flex flex-col justify-between gap-3 sm:flex-row sm:items-end">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-kumo-muted">Not just bug reports</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-kumo-default">Any repo task that needs proof.</h2>
        </div>
        <p class="max-w-md text-sm leading-6 text-kumo-strong">
          Same API shape: one repo, one Cloudflare Container runner, explicit checks, one artifact.
        </p>
      </div>

      <div class="mt-6 divide-y divide-kumo-line rounded-xl border border-kumo-line bg-kumo-elevated/20">
        {runs.map(([title, detail]) => (
          <div class="grid gap-1 px-4 py-3 sm:grid-cols-[14rem_minmax(0,1fr)] sm:items-baseline">
            <h3 class="font-medium text-kumo-default">{title}</h3>
            <p class="text-sm text-kumo-strong">{detail}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-10 grid gap-3 md:grid-cols-3">
      <div class="rounded-xl border border-kumo-line bg-kumo-elevated/20 p-4">
        <h2 class="font-semibold text-kumo-default">What is a computer?</h2>
        <p class="mt-2 text-sm leading-6 text-kumo-strong">
          A real Cloudflare Container runner for shell commands, plus Durable Object/R2 state for files, artifacts, receipts, and grading.
        </p>
      </div>
      <div class="rounded-xl border border-kumo-line bg-kumo-elevated/20 p-4">
        <h2 class="font-semibold text-kumo-default">Cloud or local?</h2>
        <p class="mt-2 text-sm leading-6 text-kumo-strong">
          Cloud runs use the Container runner deployed with your Worker. Local runs use the same shape for fast iteration and tests.
        </p>
      </div>
      <div class="rounded-xl border border-kumo-line bg-kumo-elevated/20 p-4">
        <h2 class="font-semibold text-kumo-default">How long does it take?</h2>
        <p class="mt-2 text-sm leading-6 text-kumo-strong">
          The demo runs in seconds. Real repo runs take as long as clone/install/test takes; Cloudbox records each command so slow work is still inspectable.
        </p>
      </div>
    </section>

    <section class="mt-10 rounded-2xl border border-kumo-line bg-kumo-elevated/30 p-5">
      <div class="grid gap-5 md:grid-cols-[0.8fr_1.2fr] md:items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-kumo-muted">Tools are explicit</p>
          <h2 class="mt-2 text-xl font-semibold text-kumo-default">Shell and files are built in. Add the rest.</h2>
          <p class="mt-3 text-sm leading-6 text-kumo-strong">
            Browser automation, deploy checks, internal connectors, recorders, and custom CLIs become tools the computer can use.
            Every call is recorded as part of the proof.
          </p>
        </div>
        <div
          class="max-w-full overflow-x-auto overflow-y-hidden rounded-xl border border-kumo-line p-4 [-webkit-overflow-scrolling:touch] [&>pre]:m-0 [&>pre]:w-max [&>pre]:min-w-full [&>pre]:overflow-visible [&>pre]:rounded-none [&>pre]:border-0 [&>pre]:bg-transparent [&>pre]:p-0 [&>pre]:text-xs [&>pre]:leading-5"
          style="background-color:#24292e"
        >
          <Code code={`tools: {
  browser: agentBrowser(),
  deploy: cloudflare(),
  jira: mcp("jira"),
}`} lang="ts" theme="github-dark" />
        </div>
      </div>
    </section>

    <footer class="mt-10 border-t border-kumo-line pt-6 text-sm leading-6 text-kumo-strong">
      <a
        href="https://arxiv.org/abs/2604.28181"
        class="font-medium text-kumo-default underline decoration-kumo-line underline-offset-4 hover:text-kumo-strong"
      >
        Inspired by computer-use research
      </a>
      <span>; built for real repo work on Cloudflare Containers, tight feedback loops, and human-readable proof.</span>
    </footer>
  </main>
  <style>
    @keyframes tilePulse {
      0%, 18%, 100% { opacity: 0.42; transform: scale(1); background: rgba(254, 215, 170, 0.12); }
      34%, 62% { opacity: 1; transform: scale(1.04); background: rgba(251, 173, 65, 0.38); }
      76% { opacity: 0.9; background: rgba(190, 242, 100, 0.24); }
    }
    @keyframes machineBoot {
      0%, 100% { transform: translateY(0) rotateX(0deg); box-shadow: 0 0 44px rgba(246,130,31,0.18); }
      28% { transform: translateY(-4px) rotateX(4deg); box-shadow: 0 0 76px rgba(246,130,31,0.38); }
      68% { transform: translateY(-2px) rotateX(0deg); box-shadow: 0 0 90px rgba(190,242,100,0.18); }
    }
    @keyframes scan {
      0%, 46%, 100% { transform: translateY(0); opacity: 0; }
      56% { opacity: 1; }
      72% { transform: translateY(17rem); opacity: 0; }
    }
    @keyframes artifactOut {
      0%, 62%, 100% { opacity: 0; transform: translate(-50%, 1rem) scale(0.94); }
      74%, 92% { opacity: 1; transform: translate(-50%, 0) scale(1); }
    }
    @keyframes stepGlow {
      0%, 100% { border-color: rgba(255,255,255,0.1); background: rgba(255,255,255,0.04); color: rgba(255,237,213,0.72); }
      10%, 24% { border-color: rgba(251,173,65,0.55); background: rgba(251,173,65,0.14); color: rgb(255,237,213); }
    }
    .machine { animation: machineBoot 8s ease-in-out infinite; transform-style: preserve-3d; }
    .tile { animation: tilePulse 8s ease-in-out infinite; animation-delay: calc(var(--i) * 80ms); }
    .scan { animation: scan 8s ease-in-out infinite; }
    .artifact { animation: artifactOut 8s ease-in-out infinite; }
    .boot-step { animation: stepGlow 8s ease-in-out infinite; animation-delay: calc(var(--i) * 900ms); }
  </style>
</Base>
