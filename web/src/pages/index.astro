---
export const prerender = true;

import { Code } from "astro:components";
import Base from "@/layouts/Base.astro";

const primaryCode = `import { agentBrowser, cloudbox } from "cloudbox";

const run = await cloudbox.run({
  computer: "cloud",
  repo: "https://github.com/acoyfellow/cloudbox",
  bug: "cloudbox.coey.dev returns 1101 instead of the homepage",
  tools: { browser: agentBrowser() },
  reproduce: "open the site and confirm the Worker error",
  fix: "make the homepage return 200",
  verify: ["bun run build", "bun run test", "open the site again"],
  artifact: "HANDOFF.md",
});

console.log(run);

// status: passed
// proof: reproduced 1101 → patched repo → verified HTTP 200
// artifact: HANDOFF.md
// grade: 5/5`;

const runs = [
  ["Upgrade packages", "build · test · browser check"],
  ["Find flakes", "repeat until stable"],
  ["Review PRs", "checkout · test · report"],
  ["Prove migrations", "apply · verify · handoff"],
  ["Prepare releases", "final checks · release note"],
];
---

<Base>
  <main class="mx-auto max-w-6xl px-4 py-14 md:py-20">
    <section class="grid gap-10 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] lg:items-start">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-kumo-muted">Deploy on your Cloudflare account</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-kumo-default sm:text-5xl md:text-6xl">
          Agent workspaces with proof, running on Cloudflare.
        </h1>
        <p class="mt-6 text-base leading-7 text-kumo-strong sm:text-lg sm:leading-8">
          Cloudbox is infrastructure you deploy yourself: a Worker, Durable Objects, R2 artifacts,
          and receipt-backed runs for your agents. Try the demo, read the docs, then deploy it to your account.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/demo"
            class="inline-flex items-center gap-2 rounded-md bg-kumo-contrast px-4 py-2 text-sm font-medium text-kumo-base hover:opacity-90"
          >
            Try the demo
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256">
              <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"></path>
            </svg>
          </a>
          <a
            href="/docs"
            class="inline-flex items-center gap-2 rounded-md border border-kumo-line px-4 py-2 text-sm font-medium text-kumo-default hover:bg-kumo-elevated"
          >
            Read docs
          </a>
          <a
            href="https://github.com/acoyfellow/cloudbox"
            class="inline-flex items-center gap-2 rounded-md border border-kumo-line px-4 py-2 text-sm font-medium text-kumo-default hover:bg-kumo-elevated"
          >
            GitHub
          </a>
          <a
            href="https://deploy.workers.cloudflare.com/?url=https://github.com/acoyfellow/cloudbox"
            class="inline-flex items-center gap-2 rounded-md border border-kumo-line px-4 py-2 text-sm font-medium text-kumo-default hover:bg-kumo-elevated"
          >
            Deploy to Cloudflare
          </a>
        </div>
        <p class="mt-5 max-w-xl text-sm leading-6 text-kumo-strong">
          Inspired by synthetic-computer research; built for real repo work, tight feedback loops,
          and human-readable proof.
        </p>
        <a
          href="https://arxiv.org/abs/2604.28181"
          class="mt-2 inline-flex text-sm font-medium text-kumo-default underline decoration-kumo-line underline-offset-4 hover:text-kumo-strong"
        >
          Research lineage →
        </a>
        </div>
      </div>

      <div class="rounded-2xl border border-kumo-line bg-kumo-elevated/30 p-4 shadow-sm">
        <div class="mb-3 flex items-center justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-kumo-muted">Example run</p>
            <h2 class="mt-1 text-lg font-semibold text-kumo-default">Bug in, verified patch out.</h2>
          </div>
          <span class="rounded-full border border-kumo-line px-2.5 py-1 font-mono text-xs text-kumo-strong">one repo</span>
        </div>
        <div
          class="overflow-hidden rounded-xl border border-kumo-line p-4 [&>pre]:m-0 [&>pre]:max-h-[42rem] [&>pre]:overflow-auto [&>pre]:rounded-none [&>pre]:border-0 [&>pre]:bg-transparent [&>pre]:p-0 [&>pre]:text-xs [&>pre]:leading-5"
          style="background-color:#24292e"
        >
          <Code code={primaryCode} lang="ts" theme="github-dark" />
        </div>
      </div>
    </section>

    <section class="mt-14 border-t border-kumo-line pt-10">
      <div class="flex flex-col justify-between gap-3 sm:flex-row sm:items-end">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-kumo-muted">Not just bug reports</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-kumo-default">Any repo task that needs proof.</h2>
        </div>
        <p class="max-w-md text-sm leading-6 text-kumo-strong">
          Same API shape: one repo, one clean computer, explicit checks, one artifact.
        </p>
      </div>

      <div class="mt-6 divide-y divide-kumo-line rounded-xl border border-kumo-line bg-kumo-elevated/20">
        {runs.map(([title, detail]) => (
          <div class="grid gap-1 px-4 py-3 sm:grid-cols-[14rem_minmax(0,1fr)] sm:items-baseline">
            <h3 class="font-medium text-kumo-default">{title}</h3>
            <p class="text-sm text-kumo-strong">{detail}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-10 rounded-2xl border border-kumo-line bg-kumo-elevated/30 p-5">
      <div class="grid gap-5 md:grid-cols-[0.8fr_1.2fr] md:items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-kumo-muted">Tools are explicit</p>
          <h2 class="mt-2 text-xl font-semibold text-kumo-default">Shell and files are built in. Add the rest.</h2>
          <p class="mt-3 text-sm leading-6 text-kumo-strong">
            Browser automation, deploy checks, internal connectors, recorders, and custom CLIs become tools the computer can use.
            Every call is recorded as part of the proof.
          </p>
        </div>
        <div
          class="overflow-hidden rounded-xl border border-kumo-line p-4 [&>pre]:m-0 [&>pre]:rounded-none [&>pre]:border-0 [&>pre]:bg-transparent [&>pre]:p-0 [&>pre]:text-xs [&>pre]:leading-5"
          style="background-color:#24292e"
        >
          <Code code={`tools: {
  browser: agentBrowser(),
  deploy: cloudflare(),
  jira: mcp("jira"),
}`} lang="ts" theme="github-dark" />
        </div>
      </div>
    </section>
  </main>
</Base>
