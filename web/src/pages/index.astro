---
export const prerender = true;

import { Code } from "astro:components";
import Base from "@/layouts/Base.astro";

const primaryCode = `import { generateText } from "ai";
import { createCloudbox } from "cloudbox/client";

const cloudbox = createCloudbox({ token: process.env.CLOUDBOX_API_TOKEN });

// 1. Boot a fresh computer with the repo already cloned.
const box = await cloudbox.boot({
  repo: "https://github.com/acoyfellow/cloudbox",
});

// 2. Your model decides by using tools that run in the box.
await generateText({
  model: yourModel,
  tools: box.tools(["shell", "read", "write"]),
  prompt: ` + "`" + `
    grep for the demo empty state.
    improve the copy.
    run the tests.
    write HANDOFF.md with what changed.
  ` + "`" + `,
});

// 3. Cloudbox returns the human artifact and receipts.
const proof = await box.submit("HANDOFF.md");
console.log(proof.artifact.content);
// receipts: grep → read → write → test → artifact`;

const runs = [
  ["Clone", "Start from a fresh checkout every time.", "/docs/concepts"],
  ["Boot", "Create a Cloudflare Container runner for the task.", "/docs/architecture"],
  ["Run", "Use shell, files, browser, deploy, MCP, or custom tools.", "/docs/recipes/browser-agent"],
  ["Verify", "Execute explicit checks before anything counts.", "/docs/recipes/proof-runs"],
  ["Return", "Hand back one artifact plus receipts.", "/docs/api"],
];

const learnMore = [
  ["Try the hosted demo", "Run a public GitHub repo and inspect the returned artifact and receipts.", "/demo"],
  ["Bring your agent", "Use any model. Give it Cloudbox tools for repo work, and optionally a browser.", "/docs/recipes/bring-your-agent"],
  ["Run it from CI", "Add the GitHub Actions smoke test and upload Cloudbox proof as an artifact.", "/docs/recipes/ci-cd"],
  ["Deploy your own", "Create the Worker, Durable Objects, R2, D1, and Container runner in your account.", "/docs/deploy"],
];
---

<Base>
  <main class="mx-auto max-w-6xl overflow-x-clip px-4 py-14 md:py-20">
    <section class="grid min-w-0 gap-10 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] lg:items-start">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-kumo-muted">For agent-run repo work.</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-kumo-default sm:text-5xl md:text-6xl">
          Fresh computers on Cloudflare.
        </h1>
        <p class="mt-6 text-base leading-7 text-kumo-strong sm:text-lg sm:leading-8">
          Cloudbox gives agents a clean place to clone a repo, run commands, verify the result,
          and return receipts plus one artifact for review.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/demo"
            class="inline-flex items-center gap-2 rounded-md bg-[#f38020] px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-[#faae40]"
          >
            Try demo
          </a>
          <a
            href="/docs"
            class="inline-flex items-center gap-2 rounded-md border border-kumo-line px-4 py-2 text-sm font-medium text-kumo-default hover:bg-kumo-elevated"
          >
            Browse docs
          </a>
        </div>
      </div>
      </div>

      <div class="min-w-0 rounded-2xl border border-kumo-line bg-kumo-elevated/30 p-4 shadow-sm">
        <div
          class="max-w-full overflow-x-auto overflow-y-hidden rounded-xl border border-kumo-line p-4 [-webkit-overflow-scrolling:touch] [&>pre]:m-0 [&>pre]:max-h-[42rem] [&>pre]:w-max [&>pre]:min-w-full [&>pre]:overflow-visible [&>pre]:rounded-none [&>pre]:border-0 [&>pre]:bg-transparent [&>pre]:p-0 [&>pre]:text-xs [&>pre]:leading-5"
          style="background-color:#24292e"
        >
          <Code code={primaryCode} lang="ts" theme="github-dark" />
        </div>
        <p class="mt-4 text-sm leading-6 text-kumo-strong">
          Your model runs wherever your agent runs. Cloudbox tools execute inside the fresh computer.
          <a href="/docs/recipes/bring-your-agent" class="font-medium text-kumo-default underline decoration-kumo-line underline-offset-4 hover:text-kumo-strong">
            Learn the agent pattern →
          </a>
        </p>
      </div>
    </section>

    <section class="mt-14 rounded-2xl border border-kumo-line bg-kumo-elevated/25 p-5 sm:p-6">
      <div class="grid gap-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-kumo-muted">How runs work</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-kumo-default">Cloudbox turns a structured plan into a verified artifact.</h2>
          <p class="mt-3 text-sm leading-6 text-kumo-strong">
            Cloudbox makes agent work inspectable by forcing it through the same lifecycle: clean checkout, real Container, explicit tool calls, verification, and one returned artifact.
          </p>
        </div>

        <div class="divide-y divide-kumo-line rounded-xl border border-kumo-line bg-kumo-bg/60">
          {runs.map(([title, detail, href]) => (
            <a href={href} class="grid gap-1 px-4 py-3 transition-colors hover:bg-kumo-elevated sm:grid-cols-[7rem_minmax(0,1fr)] sm:items-baseline">
              <h3 class="font-medium text-kumo-default">{title}</h3>
              <p class="text-sm text-kumo-strong">{detail} <span class="text-kumo-muted">Learn more →</span></p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="mt-10">
      <div class="mb-4">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-kumo-muted">Learn next</p>
        <h2 class="mt-2 text-2xl font-semibold tracking-tight text-kumo-default">Pick the path that matches how you want to use it.</h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {learnMore.map(([title, detail, href]) => (
          <a href={href} class="rounded-xl border border-kumo-line bg-kumo-base p-4 transition-colors hover:bg-kumo-elevated">
            <h3 class="font-semibold text-kumo-default">{title}</h3>
            <p class="mt-2 text-sm leading-6 text-kumo-strong">{detail}</p>
          </a>
        ))}
      </div>
    </section>

    <footer class="mt-10 border-t border-kumo-line pt-6 text-sm leading-6 text-kumo-strong">
      <a
        href="https://arxiv.org/abs/2604.28181"
        class="font-medium text-kumo-default underline decoration-kumo-line underline-offset-4 hover:text-kumo-strong"
      >
        Inspired by computer-use research
      </a>
      <span>; built for real repo work on Cloudflare Containers, tight feedback loops, and human-readable proof.</span>
    </footer>
  </main>
</Base>
