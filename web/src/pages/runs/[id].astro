---
import Base from "@/layouts/Base.astro";

export const prerender = false;

const runId = Astro.params.id ?? "";
const origin = new URL(Astro.request.url).origin;
const publicUrl = `${origin}/api/runs/${runId}/public`;

type Receipt = {
  type: string;
  cmd: string;
  code: number | null;
  signal: string | null;
  stdout: string;
  stderr: string;
  startedAt: string;
  finishedAt: string;
};

type RunInput = {
  repo?: string;
  ref?: string;
  commands?: string[];
  verify?: string[];
  artifact?: string;
};

type RunResult = {
  ok?: boolean;
  receipts?: Receipt[];
  artifact?: { path: string; content: string } | null;
  diff?: string;
  error?: string;
  runnerReceipts?: { type: string; ts: string; [key: string]: unknown }[];
};

type RunPayload = {
  id: string;
  createdAt: string;
  repo: string;
  status: string;
  artifact: string | null;
  input: RunInput | null;
  result: RunResult;
};

let data: RunPayload | null = null;
let notFound = false;
let fetchError: string | null = null;

if (runId) {
  try {
    const response = await fetch(publicUrl, { headers: { "user-agent": "cloudbox-runs-viewer" } });
    if (response.status === 200) {
      data = (await response.json()) as RunPayload;
    } else if (response.status === 404) {
      notFound = true;
    } else {
      fetchError = `${response.status} ${response.statusText}`;
    }
  } catch (error) {
    fetchError = error instanceof Error ? error.message : String(error);
  }
}

const title = data ? `Run ${data.id.slice(0, 16)}` : notFound ? "Run not found" : "Run";
const description = data
  ? `Cloudbox proof run on ${data.repo} — ${data.status}`
  : "A shareable Cloudbox proof run: receipts, diff, and one artifact.";

// Build the curl recipe for the Fork button. We send the same input the
// original caller sent, dropping `public` (the forker chooses on their side).
const forkInput = data?.input
  ? { ...data.input, public: undefined }
  : { repo: data?.repo ?? "", commands: ["echo ok"], verify: ["test -f package.json"], artifact: "HANDOFF.md" };
delete (forkInput as Record<string, unknown>).public;

const forkCurl = [
  `curl -X POST "$CLOUDBOX_URL/api/runs" \\`,
  `  -H "authorization: Bearer $CLOUDBOX_API_TOKEN" \\`,
  `  -H "content-type: application/json" \\`,
  `  -d '${JSON.stringify(forkInput)}'`,
].join("\n");

function statusBadge(status: string): { label: string; classes: string } {
  if (status === "passed") return { label: "passed", classes: "bg-green-50 text-green-800 border-green-200" };
  if (status === "failed") return { label: "failed", classes: "bg-amber-50 text-amber-800 border-amber-200" };
  if (status === "error") return { label: "error", classes: "bg-red-50 text-red-800 border-red-200" };
  return { label: status, classes: "bg-kumo-elevated text-kumo-strong border-kumo-line" };
}

const badge = data ? statusBadge(data.status) : null;
---

<Base title={`Cloudbox · ${title}`} description={description}>
  <main class="mx-auto max-w-4xl px-4 py-10 md:py-14">
    {notFound && (
      <div class="rounded-lg border border-kumo-line bg-kumo-elevated p-6">
        <h1 class="text-2xl font-semibold text-kumo-default">Run not found</h1>
        <p class="mt-2 text-kumo-strong">
          This run id is unknown, or the run was not posted with <code class="font-mono text-sm">public: true</code>.
        </p>
        <p class="mt-4">
          <a href="/" class="text-orange-600 hover:underline">← Back to Cloudbox</a>
        </p>
      </div>
    )}

    {fetchError && (
      <div class="rounded-lg border border-amber-200 bg-amber-50 p-6">
        <h1 class="text-xl font-semibold text-amber-900">Could not load run</h1>
        <p class="mt-2 text-amber-800 font-mono text-sm">{fetchError}</p>
      </div>
    )}

    {data && (
      <article>
        <header class="border-b border-kumo-line pb-6">
          <div class="flex flex-wrap items-center gap-3">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-kumo-muted">Cloudbox run</p>
            {badge && (
              <span class={`rounded-full border px-2.5 py-0.5 text-xs font-semibold ${badge.classes}`}>
                {badge.label}
              </span>
            )}
          </div>
          <h1 class="mt-2 break-all font-mono text-2xl text-kumo-default md:text-3xl">{data.id}</h1>
          <dl class="mt-4 grid gap-x-6 gap-y-2 text-sm text-kumo-strong sm:grid-cols-[max-content_1fr]">
            <dt class="font-semibold text-kumo-default">Repo</dt>
            <dd class="break-all">
              <a href={data.repo} class="text-orange-600 hover:underline" rel="noreferrer">{data.repo}</a>
              {data.input?.ref && <span class="ml-2 font-mono text-xs text-kumo-muted">@ {data.input.ref}</span>}
            </dd>
            <dt class="font-semibold text-kumo-default">Created</dt>
            <dd class="font-mono text-xs">{data.createdAt}</dd>
            {data.artifact && (
              <>
                <dt class="font-semibold text-kumo-default">Artifact</dt>
                <dd class="font-mono text-xs">{data.artifact}</dd>
              </>
            )}
          </dl>
        </header>

        <section class="mt-8">
          <div class="flex items-center justify-between gap-4">
            <h2 class="text-lg font-semibold text-kumo-default">Fork this run</h2>
          </div>
          <p class="mt-1 text-sm text-kumo-strong">
            Replay the same recipe against your own Cloudbox. Set <code class="font-mono text-xs">$CLOUDBOX_URL</code> to your deployment.
          </p>
          <div class="mt-3 overflow-hidden rounded-lg border border-kumo-line bg-[#0B0D10]">
            <div class="flex items-center justify-between border-b border-kumo-line/40 px-4 py-2">
              <span class="font-mono text-xs text-kumo-muted">curl</span>
              <button
                type="button"
                data-copy="fork-curl"
                class="rounded-md border border-kumo-line/40 px-3 py-1 text-xs font-medium text-kumo-strong hover:bg-kumo-elevated/20"
              >
                Copy
              </button>
            </div>
            <pre id="fork-curl" class="overflow-x-auto px-4 py-3 font-mono text-xs leading-relaxed text-kumo-default">{forkCurl}</pre>
          </div>
        </section>

        {data.input?.commands?.length || data.input?.verify?.length ? (
          <section class="mt-8">
            <h2 class="text-lg font-semibold text-kumo-default">Recipe</h2>
            <dl class="mt-3 space-y-3 text-sm">
              {data.input?.commands?.length ? (
                <div>
                  <dt class="font-semibold text-kumo-default">commands</dt>
                  <dd class="mt-1 space-y-1">
                    {data.input.commands.map((cmd) => (
                      <pre class="rounded-md border border-kumo-line bg-kumo-elevated px-3 py-1.5 font-mono text-xs text-kumo-strong">{cmd}</pre>
                    ))}
                  </dd>
                </div>
              ) : null}
              {data.input?.verify?.length ? (
                <div>
                  <dt class="font-semibold text-kumo-default">verify</dt>
                  <dd class="mt-1 space-y-1">
                    {data.input.verify.map((cmd) => (
                      <pre class="rounded-md border border-kumo-line bg-kumo-elevated px-3 py-1.5 font-mono text-xs text-kumo-strong">{cmd}</pre>
                    ))}
                  </dd>
                </div>
              ) : null}
            </dl>
          </section>
        ) : null}

        {data.result.receipts?.length ? (
          <section class="mt-8">
            <h2 class="text-lg font-semibold text-kumo-default">Receipts</h2>
            <ol class="mt-3 space-y-2">
              {data.result.receipts.map((r) => {
                const ok = r.code === 0;
                return (
                  <li class="rounded-lg border border-kumo-line bg-kumo-base p-3">
                    <div class="flex flex-wrap items-center gap-2 text-xs">
                      <span class={`font-mono ${ok ? "text-green-600" : "text-red-600"}`}>{ok ? "✓" : "✗"}</span>
                      <span class="rounded bg-kumo-elevated px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wide text-kumo-muted">{r.type}</span>
                      <span class="font-mono text-kumo-muted">code {r.code ?? "null"}</span>
                    </div>
                    <pre class="mt-1.5 overflow-x-auto font-mono text-xs text-kumo-strong">{r.cmd}</pre>
                    {(r.stdout || r.stderr) && (
                      <details class="mt-1.5">
                        <summary class="cursor-pointer text-xs text-kumo-muted hover:text-kumo-strong">output</summary>
                        {r.stdout && <pre class="mt-1 overflow-x-auto whitespace-pre-wrap font-mono text-xs text-kumo-strong">{r.stdout}</pre>}
                        {r.stderr && <pre class="mt-1 overflow-x-auto whitespace-pre-wrap font-mono text-xs text-red-700">{r.stderr}</pre>}
                      </details>
                    )}
                  </li>
                );
              })}
            </ol>
          </section>
        ) : null}

        {data.result.diff ? (
          <section class="mt-8">
            <h2 class="text-lg font-semibold text-kumo-default">Diff</h2>
            <pre class="mt-3 overflow-x-auto rounded-lg border border-kumo-line bg-kumo-elevated p-3 font-mono text-xs text-kumo-strong">{data.result.diff}</pre>
          </section>
        ) : null}

        {data.result.artifact ? (
          <section class="mt-8">
            <h2 class="text-lg font-semibold text-kumo-default">Artifact</h2>
            <p class="mt-1 font-mono text-xs text-kumo-muted">{data.result.artifact.path}</p>
            <pre class="mt-2 overflow-x-auto rounded-lg border border-kumo-line bg-kumo-base p-4 font-mono text-xs text-kumo-strong">{data.result.artifact.content}</pre>
          </section>
        ) : null}

        <footer class="mt-12 border-t border-kumo-line pt-6 text-sm text-kumo-strong">
          <p>
            Deploy your own Cloudbox →
            <a href="https://deploy.workers.cloudflare.com/?url=https://github.com/acoyfellow/cloudbox" class="ml-1 text-orange-600 hover:underline">
              one click
            </a>
            · <a href="/docs" class="text-orange-600 hover:underline">docs</a>
          </p>
        </footer>
      </article>
    )}
  </main>

  <script>
    document.querySelectorAll<HTMLButtonElement>("button[data-copy]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const targetId = btn.dataset.copy;
        if (!targetId) return;
        const target = document.getElementById(targetId);
        if (!target) return;
        try {
          await navigator.clipboard.writeText(target.textContent ?? "");
          const original = btn.textContent;
          btn.textContent = "Copied";
          btn.disabled = true;
          setTimeout(() => {
            btn.textContent = original;
            btn.disabled = false;
          }, 1500);
        } catch {
          btn.textContent = "Copy failed";
          setTimeout(() => (btn.textContent = "Copy"), 1500);
        }
      });
    });
  </script>
</Base>
