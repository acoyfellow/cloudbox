{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types", "node", "vitest/globals"],
    "paths": {
      "@/*": ["./web/src/*"]
    }
  },
  "include": ["web/**/*.ts", "web/**/*.tsx", "src/**/*.ts", "tests/**/*.ts"]
}
